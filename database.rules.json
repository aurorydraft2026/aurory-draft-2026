{
  "rules": {
    "recentMiniGameWinners": {
      ".read": true,
      ".write": false,
      ".indexOn": ["timestamp"]
    },
    "drakkar_race": {
      ".read": true,
      ".write": false,
      "presence": {
        "$uid": {
          ".write": "auth != null && auth.uid == $uid"
        }
      },
      "history": {
        ".indexOn": ["timestamp"]
      },
      "pools": {
        ".read": true,
        ".write": "auth != null",
        "$shipId": {
          ".validate": "newData.isNumber()"
        }
      }
    },
    "leaderboards": {
      "earnings": {
        "$currency": {
          "$gameId": {
            "$timeframe": {
              ".read": true,
              ".indexOn": ["score"],
              "$dateKey": {
                ".read": true,
                ".indexOn": ["score"]
              }
            }
          }
        }
      }
    }
  }
}
